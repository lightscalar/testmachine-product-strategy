    const pipelineCtx = document.getElementById('pipelineChart').getContext('2d');
    new Chart(pipelineCtx, {
      type: 'bar',
      data: {
        labels: ['Prospecting', 'Outreach', 'Engaged', 'Qualified', 'Proposal', 'Closed'],
        datasets: [{
          label: 'Prospects',
          data: [1000, 130, 80, 40, 20, 10],
          backgroundColor: [
            'oklch(0.5 0.2 0 / 0.8)',    // Red for high numbers
            'oklch(0.65 0.15 30 / 0.8)',  // Orange
            'oklch(0.70 0.15 60 / 0.8)',  // Yellow  
            'oklch(0.65 0.12 120 / 0.8)', // Light green
            'oklch(0.60 0.12 150 / 0.8)', // Green
            'oklch(0.72 0.12 192 / 0.8)'  // Accent teal
          ],
          borderColor: [
            'oklch(0.5 0.2 0)',
            'oklch(0.65 0.15 30)',
            'oklch(0.70 0.15 60)',
            'oklch(0.65 0.12 120)',
            'oklch(0.60 0.12 150)',
            'oklch(0.72 0.12 192)'
          ],
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            beginAtZero: true,
            grid: {
              color: 'oklch(0.25 0.005 260)'
            }
          },
          x: {
            grid: {
              color: 'oklch(0.25 0.005 260)'
            }
          }
        },
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            callbacks: {
              afterLabel: function(context) {
                const percentage = ((context.parsed.y / 1000) * 100).toFixed(1);
                return `${percentage}% of total prospects`;
              }
            }
          }
        }
      }
    });

    // Revenue Growth Chart
    const revenueCtx = document.getElementById('revenueChart').getContext('2d');
    new Chart(revenueCtx, {
      type: 'line',
      data: {
        labels: ['Current', 'Month 3', 'Month 6', 'Month 9', 'Month 12'],
        datasets: [
          {
            label: 'Current Revenue',
            data: [720, 720, 720, 720, 720],
            borderColor: 'oklch(0.65 0 0)',
            backgroundColor: 'oklch(0.65 0 0 / 0.1)',
            borderDash: [5, 5]
          },
          {
            label: 'Self-Serve Revenue',
            data: [0, 180, 450, 850, 1200],
            borderColor: 'oklch(0.72 0.12 192)',
            backgroundColor: 'oklch(0.72 0.12 192 / 0.1)',
            fill: '+1'
          },
          {
            label: 'Exchange Revenue',
            data: [720, 790, 920, 1150, 1600],
            borderColor: 'oklch(0.60 0.12 150)',
            backgroundColor: 'oklch(0.60 0.12 150 / 0.1)',
            fill: 'origin'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index'
        },
        scales: {
          y: {
            beginAtZero: true,
            max: 2500,
            grid: {
              color: 'oklch(0.25 0.005 260)'
            },
            ticks: {
              callback: function(value) {
                return '$' + value + 'K';
              }
            }
          },
          x: {
            grid: {
              color: 'oklch(0.25 0.005 260)'
            }
          }
        },
        plugins: {
          tooltip: {
            callbacks: {
              label: function(context) {
                return context.dataset.label + ': $' + context.parsed.y + 'K ARR';
              }
            }
          }
        }
      }
    });

    // ROI Matrix Scatter Plot
    const roiCtx = document.getElementById('roiMatrix').getContext('2d');
    new Chart(roiCtx, {
      type: 'scatter',
      data: {
        datasets: [{
          label: 'P0 Features',
          data: [
            { x: 7, y: 9, label: 'Pricing Calculator' },
            { x: 6, y: 8, label: 'Self-Serve Demo' },
            { x: 5, y: 7, label: 'Analytics Dashboard' }
          ],
          backgroundColor: 'oklch(0.72 0.12 192)',
          borderColor: 'oklch(0.72 0.12 192)',
          pointRadius: 12,
          pointHoverRadius: 15
        }, {
          label: 'Future Features',
          data: [
            { x: 4, y: 5, label: 'API Access' },
            { x: 3, y: 6, label: 'White Label' },
            { x: 8, y: 4, label: 'Mobile App' }
          ],
          backgroundColor: 'oklch(0.65 0 0 / 0.5)',
          borderColor: 'oklch(0.65 0 0)',
          pointRadius: 8,
          pointHoverRadius: 10
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            title: {
              display: true,
              text: 'Implementation Effort (1-10)'
            },
            min: 0,
            max: 10,
            grid: {
              color: 'oklch(0.25 0.005 260)'
            }
          },
          y: {
            title: {
              display: true,
              text: 'Revenue Impact (1-10)'
            },
            min: 0,
            max: 10,
            grid: {
              color: 'oklch(0.25 0.005 260)'
            }
          }
        },
        plugins: {
          tooltip: {
            callbacks: {
              title: function(context) {
                return context[0].raw.label || '';
              },
              label: function(context) {
                return `Impact: ${context.parsed.y}/10, Effort: ${context.parsed.x}/10`;
              }
            }
          },
          legend: {
            display: true
          }
        }
      }
    });

    // Add annotation for high-impact, low-effort quadrant
    const roiCanvas = document.getElementById('roiMatrix');
    const roiRect = roiCanvas.getBoundingClientRect();
    
    // Add smooth scrolling for navigation
    document.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        const targetElement = document.querySelector(targetId);
        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });

    // Add urgency countdown
    function updateUrgencyIndicator() {
      const deadline = new Date('2026-03-09 12:00:00 EST');
      const now = new Date();
      const timeDiff = deadline - now;
      
      const days = Math.floor(timeDiff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((timeDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((timeDiff % (1000 * 60 * 60)) / (1000 * 60));
      
      const indicator = document.querySelector('.urgency-indicator');
      if (timeDiff > 0) {
        indicator.textContent = `DEADLINE: ${days}d ${hours}h ${minutes}m`;
      } else {
        indicator.textContent = 'DEADLINE PASSED';
        indicator.style.background = '#dc2626';
      }
    }
    
    updateUrgencyIndicator();
    setInterval(updateUrgencyIndicator, 60000); // Update every minute
  </script>

</body>
